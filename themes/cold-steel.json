    "overlayTop": "#0F172A",
    "overlayBottom": "#1E2937",
    "muted": "#94A3B8",
    "danger": "#EF4444",
    "dangerHover": "#DC2626",
    "dangerStrong": "#B91C1C",
    "success": "#22C55E",
    "successHover": "#16A34A",
    "warning": "#F59E0B",
    "info": "#60A5FA",
    "buttonHover": "#334155",
    "accentHover": "#CBD5E1",
