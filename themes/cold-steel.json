{
  "name": "Cold Steel",
  "buttonRadius": "sm",
  "cardRadius": "sm",
  "font": "\"Inter\", \"Segoe UI\", ui-sans-serif, system-ui, sans-serif",
  "nav": {
    "layout": "sidebar",
    "displayMode": "icons",
    "accentBarEnabled": true,
    "glow": {
      "enabled": false,
      "color": "#94A3B8",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "filterSidebar": {
      "side": "right",
      "mode": "overlay"
    }
  },
  "buttonEffects": {
    "shadow": {
      "enabled": true,
      "color": "#475569",
      "offsetX": 0,
      "offsetY": 2,
      "intensity": 10
    },
    "glow": {
      "enabled": false,
      "color": "#94A3B8",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    }
  },
  "textEffects": {
    "shadow": {
      "enabled": false,
      "color": "#94A3B8",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": false,
      "color": "#94A3B8",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "contexts": {
      "navLabels": {
        "shadow": false,
        "glow": false
      },
      "pageTitles": {
        "shadow": false,
        "glow": false
      },
      "gameTitles": {
        "shadow": false,
        "glow": false
      }
    }
