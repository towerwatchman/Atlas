{
  "name": "Matrix",
  "buttonRadius": "sm",
  "cardRadius": "sm",
  "font": "\"Inter\", \"Segoe UI\", ui-sans-serif, system-ui, sans-serif",
  "nav": {
    "layout": "sidebar",
    "displayMode": "iconsAndText",
    "accentBarEnabled": true,
    "glow": {
      "enabled": true,
      "color": "#00FF41",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 15
    },
    "iconGlow": false,
    "filterSidebar": {
      "side": "right",
      "mode": "overlay"
    }
  },
  "buttonEffects": {
    "shadow": {
      "enabled": false,
      "color": "#00FF41",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": true,
      "color": "#00FF41",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 18
    }
  },
  "textEffects": {
    "shadow": {
      "enabled": false,
      "color": "#00FF41",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": true,
      "color": "#00FF41",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "contexts": {
      "navLabels": {
        "shadow": false,
        "glow": true
      },
      "pageTitles": {
        "shadow": false,
        "glow": true
      },
      "gameTitles": {
        "shadow": false,
        "glow": false
      }
    }
  },
  "windowBorderEnabled": true,
  "windowBorderRadius": "lg",
  "windowBorderHideOnMain": false,
  "colors": {
    "canvas": "#000000",
    "shadow": "#000000",
    "primary": "#0A0F0A",
    "secondary": "#0F140F",
    "tertiary": "#141A14",
    "border": "#00FF41",
    "selected": "#1A2A1A",
    "accent": "#00FF41",
    "accentBar": "#00FF41",
    "atlasLogo": "#B8E0B8",
    "text": "#B8E0B8",
    "highlight": "#00FF41",
    "overlayTop": "#000000",
    "overlayBottom": "#000000",
    "muted": "#4A8C4A",
    "danger": "#FF2D55",
    "dangerHover": "#E94560",
    "dangerStrong": "#9F1239",
    "success": "#00FF41",
    "successHover": "#00CC33",
    "warning": "#FFD700",
    "info": "#00BFFF",
    "buttonHover": "#0F140F",
    "accentHover": "#00CC33",
    "accentMuted": "#00751d",
    "button": "#0A0F0A",
    "progressBackground": "#0A0F0A",
    "progressForeground": "#00FF41",
    "library": "#0F140F",
    "windowBorder": "#00FF41",
    "detailPlay": "#00FF41",
    "detailPlayText": "#d2e885",
    "detailLaunching": "#b58e00",
    "detailRunning": "#3a6db5",
    "detailAccent": "#069d2c",
    "detailAccentText": "#c8e0ff",
    "detailWishlistAdd": "#2f5f78",
    "detailWishlistRemove": "#6b2f42",
    "detailFavorite": "#f59e0b"
  }
}
