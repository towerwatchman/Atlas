    "overlayBottom": "#000000",
    "muted": "#b1aac0",
    "danger": "DarkOliveGreen",
    "dangerHover": "#7F1D1D",
    "dangerStrong": "#7F1D1D",
    "success": "DarkOliveGreen",
    "successHover": "#6a873a",
    "warning": "#FACC15",
    "info": "#ff9326",
    "buttonHover": "#2A2733",
    "accentHover": "#6a873a",
