    "filterSidebar": {
      "side": "right",
      "mode": "inline"
    }
  },
  "buttonEffects": {
    "shadow": {
      "enabled": false,
      "color": "#181c12",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 20
    },
    "glow": {
      "enabled": true,
      "color": "#6a873a",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 20
    }
  },
  "textEffects": {
    "shadow": {
      "enabled": false,
      "color": "#2C8EA9",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": false,
      "color": "#2C8EA9",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 20
    },
    "contexts": {
      "navLabels": {
        "shadow": false,
