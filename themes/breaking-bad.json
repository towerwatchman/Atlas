{
  "name": "Breaking Bad",
  "buttonRadius": "sm",
  "cardRadius": "sm",
  "font": "\"Inter\", \"Segoe UI\", ui-sans-serif, system-ui, sans-serif",
  "nav": {
    "layout": "sidebar",
    "displayMode": "iconsAndText",
    "accentBarEnabled": true,
    "glow": {
      "enabled": true,
      "color": "#22C55E",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "iconGlow": false,
    "filterSidebar": {
      "side": "right",
      "mode": "overlay"
    }
  },
  "buttonEffects": {
    "shadow": {
      "enabled": false,
      "color": "#22C55E",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": true,
      "color": "#22C55E",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 14
    }
  },
  "textEffects": {
    "shadow": {
      "enabled": false,
      "color": "#22C55E",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": false,
      "color": "#22C55E",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "contexts": {
      "navLabels": {
        "shadow": false,
        "glow": false
      },
      "pageTitles": {
        "shadow": false,
        "glow": true
      },
      "gameTitles": {
        "shadow": false,
        "glow": false
      }
    }
  },
  "windowBorderEnabled": true,
  "windowBorderRadius": "none",
  "windowBorderHideOnMain": false,
  "colors": {
    "canvas": "#0F1114",
    "shadow": "#000000",
    "primary": "#1A1E24",
