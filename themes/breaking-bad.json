    "overlayBottom": "#000000",
    "muted": "#9CA3AF",
    "danger": "#EF4444",
    "dangerHover": "#DC2626",
    "dangerStrong": "#B91C1C",
    "success": "#22C55E",
    "successHover": "#16A34A",
    "warning": "#FACC15",
    "info": "#3B82F6",
