{
  "name": "Cyberpunk 2077",
  "buttonRadius": "sm",
  "cardRadius": "sm",
  "font": "\"Rajdhani\", \"Inter\", ui-sans-serif, system-ui, sans-serif",
  "nav": {
    "layout": "sidebar",
    "displayMode": "iconsAndText",
    "accentBarEnabled": true,
    "glow": {
      "enabled": true,
      "color": "#F5E642",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 14
    },
    "iconGlow": false,
    "filterSidebar": {
      "side": "right",
      "mode": "overlay"
    }
  },
  "buttonEffects": {
    "shadow": {
      "enabled": false,
      "color": "#F5E642",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": true,
      "color": "#F5E642",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 10
    }
  },
  "textEffects": {
    "shadow": {
      "enabled": false,
      "color": "#F5E642",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "glow": {
      "enabled": false,
      "color": "#F5E642",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "contexts": {
      "navLabels": {
        "shadow": false,
        "glow": false
      },
      "pageTitles": {
        "shadow": false,
        "glow": true
