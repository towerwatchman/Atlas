    "glow": {
      "enabled": true,
      "color": "#F59E0B",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    }
  },
  "textEffects": {
    "shadow": {
      "enabled": false,
      "color": "#F59E0B",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 10
    },
    "glow": {
      "enabled": true,
      "color": "#F59E0B",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 12
    },
    "contexts": {
      "navLabels": {
        "shadow": false,
