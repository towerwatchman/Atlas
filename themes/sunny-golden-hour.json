{
  "name": "Sunny Golden Hour",
  "buttonRadius": "lg",
  "cardRadius": "lg",
  "font": "\"Inter\", \"Segoe UI\", ui-sans-serif, system-ui, sans-serif",
  "nav": {
    "layout": "sidebar",
    "displayMode": "iconsAndText",
    "accentBarEnabled": true,
    "glow": {
      "enabled": true,
      "color": "#F59E0B",
      "offsetX": 0,
      "offsetY": 0,
      "intensity": 14
