    "iconGlow": false,
    "filterSidebar": {
      "side": "right",
      "mode": "inline"
    }
  },
  "buttonEffects": {
    "shadow": {
      "enabled": false,
      "color": "#D97706",
      "offsetX": 0,
      "offsetY": 2,
      "intensity": 10
