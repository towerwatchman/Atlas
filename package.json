{
  "name": "atlas",
  "version": "1.0.71",
  "author": {
    "name": "towerwatchman",
    "email": "towerwatchman@atlas.com"
  },
  "description": "Atlas: Open-source game and visual novel manager",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build && electron-builder --win --x64",
    "check": "node scripts/check-js.js && node scripts/check-version-utils.js && vite build && git diff --check",
    "preview": "vite preview",
    "publish": "vite build && electron-builder --win --x64 -p always",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"electron/**/*.{js,jsx}\""
  },
  "build": {
    "appId": "com.towerwatchman.atlas",
    "productName": "Atlas",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "towerwatchman",
      "repo": "Atlas",
      "releaseType": "release",
      "vPrefixedTagName": true
    },
    "files": [
      "electron/**/*",
      "dist/renderer/**/*",
      "workers/**/*",
      "src/assets/ui/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node",
      "node_modules/sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/7zip-bin/**/*",
      "node_modules/node-unrar-js/**/*",
      "workers/**/*"
    ],
    "nodeGypRebuild": false,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/images/appicon.ico"
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false,
      "perMachine": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup ${version}.${ext}",
      "include": "build/installer.nsh",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "runAfterFinish": true
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "axios": "^1.7.2",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "ini": "^5.0.0",
    "lz4js": "^0.2.0",
    "node-7z": "^0.4.0",
    "node-unrar-js": "^2.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-virtualized": "^9.22.6",
    "sharp": "^0.34.5",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.15",
    "prettier": "3.6.2",
    "tailwindcss": "^3.4.17",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.4.3",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.3",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
