{
  "name": "atlas",
  "version": "1.0.71",
  "author": {
    "name": "towerwatchman",
    "email": "towerwatchman@atlas.com"
  },
  "description": "Atlas: Open-source game and visual novel manager",
  "main": "src/main.js",
  "scripts": {
    "start": "npm run build:css && electron .",
    "atlas": "npm run build:css && electron .",
    "build": "npm run build:css && electron-builder --win --x64",
    "dev": "npm run build:css && electron . --dev",
    "build:css": "postcss src/assets/css/tailwind.css -o src/assets/css/tailwind.output.css",
    "check": "node --check src/main.js && node --check src/database.js && node --check src/renderer.js && node --check src/core/versionUtils.js && node scripts/check-jsx.js && node scripts/check-version-utils.js && node scripts/check-library-resync.js && git diff --check",
    "rebuild": "electron-builder install-app-deps",
    "structure": "node scripts/generate-structure.js > scripts/project-structure.txt",
    "publish": "npm run build:css && electron-builder --win -p always",
    "format": "prettier --write src/**/*.{js,jsx,css} && prettier --write src/assets/**/*.{js,jsx,css}",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.towerwatchman.atlas",
    "productName": "Atlas",
    "publish": {
      "provider": "github",
      "owner": "towerwatchman",
      "repo": "Atlas",
      "releaseType": "release",
      "vPrefixedTagName": true
    },
    "files": [
      "src/main.js",
      "src/database.js",
      "src/index.html",
      "src/settings.html",
      "src/gamedetails.html",
      "src/renderer.js",
      "src/App.jsx",
      "src/assets/**/*",
      "src/core/**/*",
      "src/core/scanners/**/*",
      "src/core/importer/**/*",
      "src/core/settings/**/*",
      "src/core/banner/**/*",
      "package.json",
      "node_modules/sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/node-7z/**/*",
      "node_modules/7zip-bin/**/*",
      "node_modules/node-unrar-js/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/**/*.node",
      "node_modules/sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/7zip-bin/**/*",
      "node_modules/node-unrar-js/**/*"
    ],
    "nodeGypRebuild": false,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/images/appicon.ico"
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false,
      "perMachine": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup ${version}.${ext}",
      "include": "build/installer.nsh",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "runAfterFinish": true
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@babel/standalone": "^7.29.4",
    "7zip-bin": "^5.2.0",
    "axios": "^1.7.2",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "ini": "^5.0.0",
    "lz4js": "^0.2.0",
    "node-7z": "^0.4.0",
    "node-unrar-js": "^2.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.5",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.15",
    "postcss-cli": "^10.1.0",
    "prettier": "3.6.2",
    "tailwindcss": "^3.4.17"
  }
}
